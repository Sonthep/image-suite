{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Image Renamer",
  "version": "0.1.0",
  "identifier": "com.imagerenamer.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Image Renamer",
        "width": 780,
        "height": 580,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  },
  "plugins": { }
}
